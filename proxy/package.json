{
  "name": "lomo-immich-proxy",
  "version": "1.0.0",
  "description": "API proxy translating Immich API calls to lomo-backend",
  "main": "server.ts",
  "scripts": {
    "dev": "npx tsx --watch server.ts",
    "start": "npx tsx server.ts",
    "bundle": "npx esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.cjs",
    "build:exe": "npm run bundle && npx pkg --public --no-bytecode dist/server.cjs --targets node20-win-x64 --output dist/proxy.exe",
    "build": "npm run build:exe"
  },
  "bin": "dist/server.cjs",
  "pkg": {
    "targets": [
      "node20-win-x64"
    ]
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/sharp": "^0.31.1",
    "cookie-parser": "^1.4.6",
    "express": "^4.18.2",
    "hash-wasm": "^4.12.0",
    "heic-convert": "^2.1.0",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "probe-image-size": "^7.2.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.21",
    "@types/heic-convert": "^2.1.0",
    "@types/node-fetch": "^2.6.9",
    "@types/probe-image-size": "^7.2.5",
    "@types/uuid": "^9.0.7",
    "@yao-pkg/pkg": "^6.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
